# Configura esto para tu entorno local

# Si usas Ollama localmente, la URL y la llave por defecto son estas:
OPENAI_BASE_URL="http://localhost:11434/v1"
OPENAI_API_KEY="ollama"

# Nombre del modelo que tienes descargado (ej. "llama3", "llama3:70b", "nemotron")
MODEL_NAME="llama3"

# NOTA: Si prefieres usar vLLM u otro servidor local, solo cambia el puerto (ej. 8000)
